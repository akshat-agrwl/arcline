# Copy to .env and fill in from your Supabase project (Settings -> API).
# These are the *public* anon values — safe to ship to the browser because
# Row Level Security (see supabase/schema.sql) is what actually guards the data.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
